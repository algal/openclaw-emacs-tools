{
  "name": "emacs-tools",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw plugin: Emacs tools via emacsclient",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "openclaw": "file:../openclaw",
    "typebox": "^1.1.39"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "plugin:validate": "npm run build && openclaw plugins validate --entry ./dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
